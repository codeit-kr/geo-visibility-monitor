# 값은 절대 커밋하지 말 것 — GitHub Secrets 로 주입. 로컬 검증 시에만 .env 사용.

# LLM (웹검색)
PERPLEXITY_API_KEY=
OPENAI_API_KEY=          # web_search 가능한 전용 키 (인터뷰 realtime 키와 별개)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# SERP (Naver AI Briefing · Google AI Overview)
SERPAPI_API_KEY=

# 감성·정확도 LLM 판정기 모델(웹검색 없는 저가 모델, OPENAI_API_KEY 재사용). 현행 ID 확인.
CLASSIFIER_MODEL=gpt-4.1-mini

# 측정 대상 서비스 — 쉼표구분(app 키). 미설정이면 전 서비스. 새 서비스는 config/services 에 추가.
#   예: sprint → 스프린트만 / sprint,cayde → 둘 다
ACTIVE_SERVICES=sprint

# 점진적 활성화(엔진) — 쉼표구분. 미설정이면 전부 실행.
# PoC = OpenAI + SerpApi(free) → 잘 되면 gemini(KR 2위) 추가 → 이후 claude/perplexity.
#   PoC: chatgpt,google-aio,naver-briefing → +gemini → +claude,perplexity
ACTIVE_ENGINES=chatgpt,google-aio,naver-briefing

# 측정 시각 — CI 가 주입(로컬은 ISO 문자열 직접 지정). 코드 내 argless new Date() 금지.
CAPTURED_AT=2026-06-22T00:00:00Z
