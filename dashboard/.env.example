# 데이터는 같은 레포의 ../snapshots 를 직접 읽으므로 GitHub 토큰 불필요.
# 아래는 사용자 인증(Google, codeit.com 도메인)용 — next-auth v4.

# codeit.com Workspace GCP 프로젝트의 OAuth 클라이언트 (dashboard redirect URI 등록)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# openssl rand -base64 32
NEXTAUTH_SECRET=
# 로컬: http://localhost:4350 / 배포: 실제 URL (Vercel은 자동 추론, 커스텀 도메인은 명시)
NEXTAUTH_URL=http://localhost:4350
